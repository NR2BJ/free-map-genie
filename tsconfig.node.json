{
  "compilerOptions": {
    "composite": true,
    "target": "esnext",
    "module": "esnext",
    "lib": ["ESNext"],
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["@wxt-dev/module-react"]
  },
  "include": ["modules", "*.ts", "*.js", "env.d.ts"]
}
